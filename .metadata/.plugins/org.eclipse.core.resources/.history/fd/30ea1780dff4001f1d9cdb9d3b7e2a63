package ch01.ex10;

public class OperationExample {

	public static void main(String[] args) {

		int a = 1; //a = 1
		
		//a = a + 1
		//a = a +1;
		a += 1; //a = 2
		
		System.out.println(a);
 
		a++; //a = 3
		++a; //a = 4
		System.out.println(a);
	
		a*= 3; //a = 12
		System.out.println(a);
		
		a -= 10;
		System.out.println(a);
	}

}
